# Postgres connection string used by Prisma and the app.
DATABASE_URL="postgresql://hsht:hsht@localhost:5432/hsht?schema=public"

# Session/auth secret (generate with `openssl rand -base64 32`)
AUTH_SECRET=""

# Base URL the app is served from (used for callback URLs, emails, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Legacy SQL Server, for the one-way sync (npm run sync:legacy) — see MIGRATION.md.
# Never commit real values; set these directly in the environment's real .env.
LEGACY_MSSQL_HOST=""
LEGACY_MSSQL_PORT="1433"
LEGACY_MSSQL_USER=""
LEGACY_MSSQL_PASSWORD=""
LEGACY_MSSQL_DATABASE=""
LEGACY_MSSQL_ENCRYPT="true"
LEGACY_MSSQL_TRUST_SERVER_CERTIFICATE="true"
